<configuration>

    <springProperty name="svc_name" source="spring.application.name" scope="context"/>
    <springProperty name="svc_profile" source="proj.profile" scope="context"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d [%-28.28logger{28}] [${svc_name}] [${svc_profile}] [%thread] [%-5level] %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="org.springframework.ai.chat.client.observation" level="DEBUG"/>
    <logger name="org.springframework.ai.chat.client.advisor" level="DEBUG"/>

</configuration>